library(caret)
# Nota: O pacote ElemStatLearn foi arquivado no CRAN.
# Se houver erro ao carregá-lo, você pode usar a base do pacote 'bestglm'.
# install.packages("bestglm")
# data(SAheart, package = "bestglm")
# Carregar o conjunto de dados (assumindo que o pacote ElemStatLearn está disponível)
data("SAheart", package = "ElemStatLearn")
df <- SAheart
# IMPORTANTE: Converter a variável desfecho 'chd' para fator.
# Isso garante que a função createFolds aplique a estratificação por classe
# e não a estratificação por percentis numéricos.
df$chd <- as.factor(df$chd)
# 2. Definir a semente aleatória e os valores de k
semente_utilizada <- 12345
valores_k <- c(3, 5, 10)
# Função auxiliar para apresentar a tabela de distribuição em frequências e percentuais
tabela_distribuicao <- function(dados, nome_conjunto) {
freq_abs <- table(dados$chd)
freq_rel <- prop.table(freq_abs) * 100
res <- data.frame(
Classe = names(freq_abs),
Frequencia_Absoluta = as.vector(freq_abs),
Percentual = round(as.vector(freq_rel), 2)
)
cat(paste("Distribuição do desfecho (chd) -", nome_conjunto, ":\n"))
print(res, row.names = FALSE)
cat("\n")
}
# 3, 4 e 5. Laço para cada valor de k
for (k in valores_k) {
cat(rep("=", 60), "\n")
cat(sprintf("INICIANDO VALIDAÇÃO CRUZADA K-FOLD COM k = %d\n", k))
cat(rep("=", 60), "\n\n")
# Fixar a semente logo ANTES da divisão para garantir reprodutibilidade
set.seed(semente_utilizada)
# Realizar a divisão estratificada. 'returnTrain = FALSE' retorna os índices de TESTE.
folds_teste <- createFolds(df$chd, k = k, list = TRUE, returnTrain = FALSE)
# Verificação de Consistência (i): Cada observação é usada exatamente uma vez no teste?
todos_indices_teste <- unlist(folds_teste)
consistente_tamanho <- length(unique(todos_indices_teste)) == nrow(df)
cat(sprintf(">> Verificação (i): Cada observação é usada exatamente uma vez como teste? %s\n\n",
ifelse(consistente_tamanho, "SIM", "NÃO")))
# Iterar sobre cada fold i
for (i in 1:k) {
cat(rep("-", 40), "\n")
cat(sprintf("Resumo para o Fold %d de %d\n", i, k))
cat(sprintf("Semente aleatória base: %d\n", semente_utilizada))
# Construir subconjuntos
idx_teste <- folds_teste[[i]]
df_teste <- df[idx_teste, ]
df_treino <- df[-idx_teste, ] # Observações complementares ao fold i
# O número de observações e o percentual em cada subconjunto
n_total <- nrow(df)
n_treino <- nrow(df_treino)
n_teste <- nrow(df_teste)
cat(sprintf("Conjunto de Treinamento: %d observações (%.2f%%)\n", n_treino, (n_treino/n_total)*100))
cat(sprintf("Conjunto de Teste: %d observações (%.2f%%)\n\n", n_teste, (n_teste/n_total)*100))
# A distribuição das classes do desfecho
tabela_distribuicao(df_treino, "Treinamento")
tabela_distribuicao(df_teste, "Teste")
# Amostra das primeiras observações
cat("Primeiras observações do subconjunto de Treinamento (amostra):\n")
print(head(df_treino, 3))
cat("\nPrimeiras observações do subconjunto de Teste (amostra):\n")
print(head(df_teste, 3))
cat("\n")
}
}
iqr_score <- function(x, na.rm = FALSE){
if (na.rm == TRUE){
x <- na.omit(x)
}
(x-median(x))/IQR(x)
}
cancer_iqr_score <- cancer %>%
select(where(is.numeric)) %>%
apply(.,2,iqr_score, na.rm = TRUE)
