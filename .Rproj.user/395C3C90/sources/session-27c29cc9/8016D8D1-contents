## Atividade Prática 3.3

```{r}
library(mlbench)
```

```{r}
data("PimaIndiansDiabetes")

db <- PimaIndiansDiabetes
head(db)
```

Tratamento de dados

```{r}
db$diabetes <- relevel(factor(db$diabetes), ref = "neg")

```

NA's

```{r}
colSums(is.na(db))
```

Selecionar apenas valores positivos (> 0 - para evitar incoerência clínica)

```{r}
db_novo <- subset(db, glucose > 0)
db_novo <- subset(db_novo , pressure > 0)
db_novo <- subset(db_novo, triceps > 0)
db_novo <- subset(db_novo, insulin > 0)
db_novo <- subset(db_novo, mass > 0)
db_novo <- subset(db_novo, pedigree > 0)
db_novo <- subset(db_novo, age > 0)

dim(db)
dim(db_novo)
```

Seleção via teste de hipóteses:

```{r}

y <- db_novo$diabetes
X <- db_novo[,-9]

vars <- names(X)
res_t <-  data.frame(variaveis = vars, estatistica = NA, p_valor = NA)
res_w <-  data.frame(variaveis = vars, estatistica = NA, p_valor = NA)
res_n <-  data.frame(variaveis = vars,  p_neg = NA, p_pos = NA)

for(i in seq_along(vars)){
  v <-  vars[i]
  x_neg <- db_novo[y == 'neg', v]
  x_pos <- db_novo[y == 'pos', v]
  
  # Normalidade para o teste t
  
  sh_neg <- shapiro.test(as.numeric(x_neg))
  sh_pos <- shapiro.test(as.numeric(x_pos))
  
  res_n$p_neg[i] <- sh_neg$p.value
  res_n$p_pos[i] <- sh_pos$p.value
  
  # Teste t
  
  test_t <- t.test(db_novo[[v]]~y)
  
  res_t$estatistica[i] <- test_t$statistic
  res_t$p_valor[i] <-  test_t$p.value
  
  # Teste Wilcoxon
  
  test_w <- wilcox.test(db_novo[[v]]~y)
  
  res_w$estatistica[i] <- test_w$statistic
  res_w$p_valor[i] <-  test_w$p.value
}

```


