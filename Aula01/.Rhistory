knitr::opts_chunk$set(echo = TRUE)
# Criar um baralho padrão
valores <- c(2:10, "J", "Q", "K", "A")
naipes <- c("♠", "♥", "♦", "♣")
baralho <- expand.grid(valor = valores, naipe = naipes, stringsAsFactors = FALSE)
knitr::opts_chunk$set(echo = TRUE)
# Criar um baralho padrão
valores <- c(2:10, "J", "Q", "K", "A")
naipes <- c("♠", "♥", "♦", "♣")
baralho <- expand.grid(valor = valores, naipe = naipes, stringsAsFactors = FALSE)
sortear_cartas <- function(baralho, n) {
baralho[sample(nrow(baralho), n), ]
}
converter_para_pontos <- function(valores) {
sapply(valores, function(v) {
if (v == "J") return(11)
if (v == "Q") return(12)
if (v == "K") return(13)
if (v == "A") return(11)
return(as.numeric(v))
})
}
avaliar_mao <- function(mao) {
valores <- mao$valor
naipes <- mao$naipe
valores_numericos <- converter_para_pontos(valores)
tab <- table(valores)
rep_counts <- sort(table(tab), decreasing = TRUE)
flush <- length(unique(naipes)) == 1
valores_ord <- sort(as.numeric(valores_numericos))
# Verificar sequência
sequencia <- all(diff(valores_ord) == 1) ||
all(sort(valores_ord) == c(10,11,12,13,11))  # Royal Flush
# Classificações simplificadas
if (flush && sequencia && max(valores_ord) == 13) return(list(tipo="Royal Flush", mult=10))
if (flush && sequencia) return(list(tipo="Straight Flush", mult=9))
if (4 %in% tab) return(list(tipo="Quadra", mult=8))
if (3 %in% tab && 2 %in% tab) return(list(tipo="Full House", mult=7))
if (flush) return(list(tipo="Flush", mult=6))
if (sequencia) return(list(tipo="Straight", mult=5))
if (3 %in% tab) return(list(tipo="Trinca", mult=4))
if (sum(tab == 2) == 2) return(list(tipo="Dois Pares", mult=3))
if (2 %in% tab) return(list(tipo="Par", mult=2))
return(list(tipo="Carta Alta", mult=1))
}
pontuacao_mao <- function(mao) {
pontos <- sum(converter_para_pontos(mao$valor))
classificacao <- avaliar_mao(mao)
total <- pontos * classificacao$mult
list(mao = mao, tipo = classificacao$tipo, multiplicador = classificacao$mult, pontos = pontos, total = total)
}
# Embaralhar e sortear 5 cartas
baralho_jogo <- baralho
mao <- sortear_cartas(baralho_jogo, 5)
print(mao)
# (AQUI: interatividade com readline ou escolha programada das cartas a descartar)
# Após trocas e segunda rodada:
resultado <- pontuacao_mao(mao)
print(resultado)
